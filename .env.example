CARD_HASH_SECRET=yon_chaine_aleatoire_32_karakter_omwen
# Kle pou hash kle API machann (rekomande — si vid, itilize CARD_HASH_SECRET)
API_KEY_HASH_SECRET=lot_chaine_aleatoire_pou_api_keys
ADMIN_GATE_PASSWORD=modpas_admin_ou_a
ADMIN_GATE_SECRET=lot_chaine_aleatoire_pou_cookie

# Rekomande pou voye imèl klyan depi paj admin (app/api/send-email)
RESEND_API_KEY=re_xxx

# Opsyonèl: CAPTCHA (Cloudflare Turnstile) apre plizyè tantativ koneksyon echwe.
# Si yo pa konfigire, sistèm nan kontinye fonksyone san CAPTCHA.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

TELEGRAM_ADMIN_BOT_TOKEN=...
TELEGRAM_ADMIN_CHAT_ID=...
TELEGRAM_FINANCE_BOT_TOKEN=...
TELEGRAM_FINANCE_CHAT_ID=...

# Opsyonèl men rekòmande:
UPSTASH_REDIS_REST_URL=...
UPSTASH_REDIS_REST_TOKEN=...

# Opsyonèl: Deploy Hook Vercel (Settings > Git > Deploy Hooks) — npm run live ap rele l otomatikman
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_xxx/xxx

# GitHub Actions deploy (Settings > Secrets > Actions): VERCEL_TOKEN, VERCEL_ORG_ID, VERCEL_PROJECT_ID

# Opsyonèl: aplike migrasyon 20260721 otomatikman (npm run db:apply:balance)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Opsyonèl: test live API (npm run test:live)
TEST_API_KEY=
TEST_CARD_NUMBER=
TEST_CARD_CVV=
TEST_CARD_EXP=12/28
TEST_AMOUNT=100

# ============================================================
# OPERASYON — BACKUP & PCI (pa gen kle pou konfigire, se yon rapèl)
# ============================================================
# BACKUP:
#  - Supabase fè backup otomatik chak jou (plan Pro+) — Dashboard > Database >
#    Backups. Verifye Point-in-Time Recovery (PITR) aktive pou platfòm sa a,
#    epi fè yon tès restorasyon regilyèman (omwen 1 fwa chak trimès).
#  - Kenbe yon kopi manyèl (pg_dump) anvan chak migrasyon SQL enpòtan.
#
# PCI DSS:
#  - HatexCard sèvi ak yon modèl "kat vityèl" entèn (pa yon processor kat
#    tradisyonèl tankou Visa/Mastercard dirèkteman) — men nimewo kat/CVV
#    yo toujou done sansib. CVV pa janm anrejistre an klè (gade
#    lib/security/hash.ts), e dokiman KYC nan yon bucket prive.
#  - Anvan nenpòt entegrasyon ak yon processor kat REYÈL (Visa/Mastercard/
#    Moncash API dirèk, elt.), fè yon evalyasyon SAQ (Self-Assessment
#    Questionnaire) ak yon konseye konfòmite PCI pou detèmine ki nivo ki
#    aplike pou HatexCard.